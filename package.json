{
  "name": "wearo-admin",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "prisma generate && next build",
    "start": "next start -p 3001",
    "lint": "next lint",
    "postinstall": "prisma generate",
    "db:push": "dotenv -e .env.local -- prisma db push",
    "db:studio": "dotenv -e .env.local -- prisma studio",
    "set-admin": "dotenv -e .env.local -- node scripts/set-admin-role.cjs",
    "seed:products": "node scripts/seed-products.cjs",
    "upload:r2-catalog": "node scripts/upload-catalog-images-to-r2.cjs",
    "upload:r2-site": "node scripts/upload-site-images-to-r2.cjs"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@aws-sdk/client-s3": "^3.1024.0",
    "@prisma/client": "^6.19.0",
    "@radix-ui/react-accordion": "^1.2.0",
    "@radix-ui/react-dialog": "^1.1.1",
    "@radix-ui/react-icons": "^1.3.0",
    "@radix-ui/react-navigation-menu": "^1.2.0",
    "@radix-ui/react-select": "^2.1.1",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slider": "^1.2.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@reduxjs/toolkit": "^2.2.7",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "embla-carousel-react": "^8.2.1",
    "framer-motion": "^11.5.4",
    "holy-loader": "^2.3.7",
    "lucide-react": "^0.438.0",
    "next": "14.2.7",
    "next-auth": "^5.0.0-beta.30",
    "react": "^18",
    "react-dom": "^18",
    "react-icons": "^5.3.0",
    "react-redux": "^9.1.2",
    "react-simple-star-rating": "^5.1.7",
    "react-toastify": "^10.0.6",
    "redux-persist": "^6.0.0",
    "sanitize-html": "^2.17.2",
    "tailwind-merge": "^2.5.2",
    "tailwindcss-animate": "^1.0.7",
    "usehooks-ts": "^3.1.0",
    "vaul": "^0.9.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/sanitize-html": "^2.16.1",
    "dotenv-cli": "^11.0.0",
    "postcss": "^8",
    "prisma": "^6.19.0",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
